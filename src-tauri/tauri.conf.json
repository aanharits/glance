{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Glance",
  "version": "0.1.0",
  "identifier": "id.aan.glance",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://generativelanguage.googleapis.com https://api.groq.com"
    },
    "windows": [
      {
        "label": "popup",
        "title": "Glance",
        "width": 380,
        "height": 120,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "visible": false,
        "shadow": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}